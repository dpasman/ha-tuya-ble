{
  "config": {
    "abort": {
      "no_unconfigured_devices": "No unconfigured devices found."
    },
    "error": {
      "device_not_registered": "Device is not registered in Tuya cloud",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "invalid_local_key": "Invalid or empty local key",
      "local_key_credentials_failed": "Local key accepted but credentials could not be built — the key may be incorrect or the cloud cache is stale",
      "login_error": "Login error ({code}): {msg}"
    },
    "flow_title": "{name}",
    "step": {
      "device": {
        "data": {
          "address": "Tuya BLE device"
        },
        "description": "Select Tuya BLE device to setup. Device must be registered in the cloud using the mobile application. It's better to unbind the device from Tuya Bluetooth gateway, if any."
      },
      "link_device": {
        "data": {
          "device_id": "Tuya cloud device"
        },
        "description": "The Bluetooth MAC address does not match the Tuya cloud MAC (this is normal for some devices). Select which cloud device corresponds to your BLE device."
      },
      "enter_local_key": {
        "data": {
          "local_key": "Local key"
        },
        "description": "The Tuya cloud API did not return the local encryption key for this device. You can find it on the Tuya IoT Platform under your project → Devices → Device details, or by using the LocalTuya method. Enter the local key (usually 16 characters) below."
      },
      "manual": {
        "data": {
          "address": "Bluetooth MAC address"
        },
        "description": "No Tuya BLE devices were automatically discovered. Enter the Bluetooth MAC address of your device manually. You can find it in Settings → System → Bluetooth."
      },
      "login": {
        "data": {
          "access_id": "Tuya IoT Access ID",
          "access_secret": "Tuya IoT Access Secret",
          "country_code": "Country",
          "password": "[%key:common::config_flow::data::password%]",
          "username": "Account"
        },
        "description": "Tuya BLE requires obtaining encryption key from Tuya cloud. Almost all devices only need to access the cloud once during setup.\n\nRefer to documentation of Tuya integration to retrive the cloud credentials https://www.home-assistant.io/integrations/tuya/\n\nEnter your Tuya credentials."
      }
    }
  },
